# ==========================================
# i3blocks — Nord Minimal
# ==========================================

separator_block_width=15
markup=pango

# ------------------------------------------
# Wireless
# ------------------------------------------
[wifi]
command=SSID=$(nmcli -t -f active,ssid dev wifi | grep '^yes' | cut -d: -f2); if [ -n "$SSID" ]; then echo "  $SSID"; else echo "󰖪 offline"; fi
interval=5
color=#88C0D0

# ------------------------------------------
# CPU
# ------------------------------------------

[cpu]
command=top -bn1 | grep "Cpu(s)" | awk '{print "󰍛 " 100 - $8 "%"}'
interval=2
color=#EBCB8B

# ------------------------------------------
# Memory
# ------------------------------------------

[memory]
command=free -h | awk '/Mem:/ {print "󰘚 " $3 "/" $2}'
interval=5
color=#A3BE8C

# ------------------------------------------
# Disk
# ------------------------------------------

[disk]
command=df -h / | awk 'NR==2 {print " " $4}'
interval=30
color=#B48EAD

# ------------------------------------------
# Battery
# ------------------------------------------

[battery]
command=acpi -b | awk -F', ' '{print "󰁹 " $2}'
interval=30
color=#D08770

# ------------------------------------------
# Clock (CENTER)
# ------------------------------------------

[time]
command=date '+󰃰 %d/%m  󰥔 %H:%M'
interval=60
align=center
min_width=40
color=#ECEFF4
